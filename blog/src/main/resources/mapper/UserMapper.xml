<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ssw.blog.mapper.UserMapper">
    <!-- 通用查询映射结果 -->
    <resultMap id="BaseResultMap" type="com.ssw.blog.pojo.User">
        <id column="user_id" property="userId"/>
        <result column="username" property="username"/>
        <result column="password" property="password"/>
        <result column="sex" property="sex"/>
        <result column="header" property="header"/>
        <result column="nickname" property="nickname"/>
        <result column="user_email" property="userEmail"/>
        <result column="created_time" property="createdTime"/>
        <result column="update_time" property="updateTime"/>
    </resultMap>

    <!-- 通用查询结果列 -->
    <sql id="Base_Column_List">
        user_id, username, password,  sex, header, nickname, user_email, created_time, update_time
    </sql>
    <insert id="save" parameterType="com.ssw.blog.pojo.User">
        insert into bl_user(
        username, password, sex, header, nickname, user_email
        ) values (
        #{username}, #{password},  #{sex},
        #{header}, #{nickname}, #{userEmail}
        )
    </insert>
    <update id="update" parameterType="com.ssw.blog.pojo.User">
        update bl_user
      <set>
        <if test="username!=null and username!=''">
            username = #{username},
        </if>
        <if test="password!=null and password!=''">
            password = #{password},
        </if>
        <if test="sex!=null and sex!=''">
            sex = #{sex},
        </if>
        <if test="header!=null and header!=''">
            header = #{header},
        </if>
        <if test="nickname!=null and nickname!=''">
            nickname = #{nickname},
        </if>
        <if test="userEmail!=null and userEmail!=''">
            user_email = #{userEmail},
        </if>
      </set>
        where user_id = #{userId}
    </update>
    <delete id="deleteById">
        delete from bl_user where user_id = #{id}
    </delete>
    <update id="updateInfo">
        update bl_user
        <set>
            <if test="username!=null and username!=''">
                username = #{username},
            </if>
            <if test="password!=null and password!=''">
                password = #{password},
            </if>
            <if test="sex!=null and sex!=''">
                sex = #{sex},
            </if>
            <if test="header!=null and header!=''">
                header = #{header},
            </if>
            <if test="nickname!=null and nickname!=''">
                nickname = #{nickname},
            </if>
            <if test="userEmail!=null and userEmail!=''">
                user_email = #{userEmail},
            </if>
        </set>
        where user_id = #{userId}
    </update>
    <select id="getById" resultMap="BaseResultMap">
        select
        user_id, username,  sex, header,
        nickname, user_email
        from bl_user
        where user_id = #{id}
    </select>
    <select id="getByPage" parameterType="com.ssw.blog.utils.Page" resultMap="BaseResultMap">
        select
        user_id, username, sex, header, nickname, user_email, created_time, update_time
        from bl_user
        <where>
        <if test="params.username!=null and params.username!=''">
             username like CONCAT('%', #{params.username}, '%')
        </if>
        <if test="params.sex!=null and params.sex!=''">
            and  sex = #{params.sex}
        </if>
        <if test="params.nickname!=null and params.nickname!=''">
            and nickname like CONCAT('%', #{params.nickname}, '%')
        </if>
        <if test="params.userEmail!=null and params.userEmail!=''">
            and user_email like CONCAT(#{params.userEmail}, '%')
        </if>
        </where>
        <if test="sortColumn!=null and sortColumn!=''">
            order by ${sortColumn} ${sortMethod}
        </if>
        limit #{index}, #{pageSize}
    </select>
    <select id="getCountByPage" parameterType="com.ssw.blog.utils.Page" resultType="java.lang.Integer">
        select
        count(*)
        from bl_user
        <where>
        <if test="params.username!=null and params.username!=''">
            username = #{params.username}
        </if>
        <if test="params.sex!=null and params.sex!=''">
            and sex = #{params.sex}
        </if>
        <if test="params.nickname!=null and params.nickname!=''">
            and nickname like CONCAT('%', #{params.nickname}, '%')
        </if>
        <if test="params.userEmail!=null and params.userEmail!=''">
            and user_email like CONCAT(#{params.userEmail}, '%')
        </if>
        </where>
    </select>
    <select id="getByUsername" resultMap="BaseResultMap">
        select
        user_id, username,password,sex, header,
        nickname, user_email
        from bl_user
        where username = #{username}
    </select>
</mapper>
