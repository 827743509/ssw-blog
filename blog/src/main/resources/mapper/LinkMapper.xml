<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ssw.blog.mapper.LinkMapper">
    <!-- 通用查询映射结果 -->
    <resultMap id="BaseResultMap" type="com.ssw.blog.pojo.Link">
        <id column="link_id" property="linkId"/>
        <result column="link_name" property="linkName"/>
        <result column="link_url" property="linkUrl"/>
        <result column="created_time" property="createdTime"/>
        <result column="update_time" property="updateTime"/>
    </resultMap>

    <!-- 通用查询结果列 -->
    <sql id="Base_Column_List">
        link_id,
        link_name,
        link_url,
        created_time,
        update_time
    </sql>
    <insert id="save" parameterType="com.ssw.blog.pojo.Link">
        insert  into bl_link(link_name, link_url)
        values (#{linkName},#{linkUrl})
    </insert>
    <update id="update" parameterType="com.ssw.blog.pojo.Link">
        update bl_link
        <set>
            <if test="linkName!=null  and linkName!=''">
                link_name=#{linkName},
            </if>
            <if test="linkUrl!=null  and linkUrl!=''">
               link_url=#{linkUrl},
            </if>
        </set>
        where link_id=#{linkId}
    </update>
    <delete id="deleteById">
        delete from bl_link where link_id=#{id}
    </delete>
    <select id="getById" resultMap="BaseResultMap">
        select
        link_id,
        link_name,
        link_url
        from bl_link
        where link_id=#{id}

    </select>
    <select id="getAll" resultMap="BaseResultMap">
        select  link_id,
        link_name,
        link_url,
          created_time,
        update_time
        from bl_link
        where link_name != '百度'
        and lower(link_name) != 'baidu'
        and lower(link_url) not like '%baidu.com%'
    </select>


</mapper>
