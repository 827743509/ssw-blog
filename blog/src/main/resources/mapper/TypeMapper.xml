<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ssw.blog.mapper.TypeMapper">
    <!-- 通用查询映射结果 -->
    <resultMap id="BaseResultMap" type="com.ssw.blog.pojo.Type">
        <id column="type_id" property="typeId"/>
        <result column="type_name" property="typeName"/>
    </resultMap>

    <!-- 通用查询结果列 -->
    <sql id="Base_Column_List">
        type_id, type_name
    </sql>
    <insert id="insert" parameterType="com.ssw.blog.pojo.Type">
       insert  into  bl_type (type_name) values (#{typeName})
    </insert>
    <update id="update" parameterType="com.ssw.blog.pojo.Type">
     update bl_type
        <set>
         <if test="typeName!=null and typeName!=''">
              type_name=#{typeName},
         </if>
        </set>
        where type_id=#{typeId}
    </update>
    <delete id="deleteById">
       delete from bl_type where type_id=#{id}
    </delete>
    <select id="getByName" resultMap="BaseResultMap">
     select type_id, type_name from bl_type where type_name=#{typeName}
    </select>
    <select id="findAll" resultMap="BaseResultMap">
        select type_id, type_name from bl_type
    </select>
    <select id="getTypeList" resultMap="BaseResultMap">
         select type_id, type_name from bl_type
    </select>
    <select id="getById" resultMap="BaseResultMap">
        select type_id, type_name from bl_type where type_id=#{id}
    </select>

</mapper>
